---
/*
  THROWAWAY PROTOTYPE — Full Force block layout exploration.
  3 structurally different variants, switch via ?variant=A|B|C + bottom bar.
  Question: which structural layout for the Full Force film case?
  Delete this file once a variant is chosen and folded into CinemaTrailer.astro.
*/
import Layout from '../layouts/Layout.astro';
import cinemaData from '../data/cinema.json';
import { extractYoutubeId } from '../lib/youtube';

const ff = cinemaData.fullforce;
const ffYt = extractYoutubeId(ff.youtubeUrl);
const thumb = `https://img.youtube.com/vi/${ffYt}/maxresdefault.jpg`;
---

<Layout>
  <main class="proto">

    <!-- ───────── Variant A — Editorial split (poster left) ───────── -->
    <section class="vbox" data-variant="A">
      <div class="seclabel"><span class="n">04</span><span class="ln"></span><span>Cinema &amp; Trailer</span></div>
      <div class="vA">
        <figure class="vA-poster">
          <img src={ff.poster} alt="" />
          <figcaption>Poster</figcaption>
        </figure>
        <div class="vA-right">
          <header class="vA-head">
            <span class="eyebrow">Feature Film</span>
            <h2 class="display">{ff.title}</h2>
            <span class="sub">{ff.subtitle}</span>
          </header>
          <a class="vA-video vplay" href="#" data-yt={ffYt} style={`background-image:linear-gradient(180deg,rgba(0,0,0,0) 40%,rgba(0,0,0,.5)),url(${thumb})`}>
            <span class="play"></span>
            <span class="cap">Watch the Film</span>
          </a>
          <a class="vA-vinyl vbuyable" href={ff.buyUrl} target="_blank" rel="noopener">
            <img src={ff.vinyl} alt="" />
            <div class="vA-vinyl-meta">
              <span class="eyebrow">Original Vinyl</span>
              <span class="buy">Buy Vinyl →</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- ───────── Variant D — Poster centre, video left / vinyl right ───────── -->
    <section class="vbox" data-variant="D" hidden>
      <div class="seclabel"><span class="n">04</span><span class="ln"></span><span>Cinema &amp; Trailer</span></div>
      <header class="vD-head">
        <span class="eyebrow">Feature Film</span>
        <h2 class="display">{ff.title}</h2>
        <span class="sub">{ff.subtitle}</span>
      </header>
      <div class="vD-row">
        <a class="vD-video vplay" href="#" data-yt={ffYt} style={`background-image:linear-gradient(180deg,rgba(0,0,0,0) 45%,rgba(0,0,0,.55)),url(${thumb})`}>
          <span class="play"></span>
          <span class="cap">Watch the Film</span>
        </a>
        <figure class="vD-poster">
          <img src={ff.poster} alt="" />
        </figure>
        <a class="vD-vinyl vbuyable" href={ff.buyUrl} target="_blank" rel="noopener">
          <img src={ff.vinyl} alt="" />
          <div class="vinyl-overlay"><span class="buy-btn">Buy Vinyl</span></div>
        </a>
      </div>
    </section>

  </main>

  <!-- Lightbox -->
  <div class="plb" id="plb" aria-hidden="true">
    <button class="plb-close" id="plbClose" aria-label="Close">×</button>
    <div class="plb-frame"><iframe id="plbFrame" allow="autoplay; encrypted-media" allowfullscreen></iframe></div>
  </div>

  <!-- Floating prototype switcher -->
  <div class="proto-bar" id="protoBar">
    <button id="prevV" aria-label="Previous">←</button>
    <span id="curV">A — Editorial split</span>
    <button id="nextV" aria-label="Next">→</button>
  </div>
</Layout>

<style>
  .proto { min-height: 100vh; padding: 80px 0 140px; }
  .vbox { max-width: 1180px; margin: 0 auto; padding: 0 32px; }
  .seclabel { display:flex; align-items:center; gap:14px; margin-bottom:40px; font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:.22em; color: var(--fg-dim); text-transform:uppercase; }
  .seclabel .n { color: var(--fg); }
  .seclabel .ln { width:60px; height:1px; background: var(--rule); }
  .eyebrow { font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:.3em; text-transform:uppercase; color: var(--fg-dim); }
  .display { font-family:'Cormorant Garamond',serif; font-weight:300; font-size:clamp(40px,6vw,76px); line-height:1; margin:12px 0 8px; }
  .sub { font-family:'IBM Plex Mono',monospace; font-size:12px; letter-spacing:.16em; text-transform:uppercase; color: var(--fg-dim); }

  /* shared video play affordance — hidden until hover */
  .vplay { position:relative; display:block; background:#161616 center/cover no-repeat; overflow:hidden; cursor:none; }
  .vplay .play { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:64px;height:64px;border-radius:50%;border:1px solid var(--fg); display:flex;align-items:center;justify-content:center; opacity:0; transition:opacity .35s ease, transform .5s ease; }
  .vplay:hover .play { opacity:1; }
  .vplay .play::after { content:""; width:0;height:0;border-left:13px solid var(--fg); border-top:8px solid transparent; border-bottom:8px solid transparent; margin-left:4px; }
  .vplay .cap { position:absolute; left:0; bottom:0; padding:16px; font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:.24em; text-transform:uppercase; }

  /* ── Variant A ── */
  .vA { display:grid; grid-template-columns: minmax(260px,36%) 1fr; gap:1px; background:var(--rule); border:1px solid var(--rule); }
  .vA-poster, .vA > .vA-right { background: var(--bg); }
  .vA-poster { position:relative; margin:0; overflow:hidden; }
  .vA-poster img { width:100%; height:100%; object-fit:cover; display:block; }
  .vA-poster figcaption { position:absolute; bottom:0;left:0;right:0; padding:14px 16px; font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:.24em; text-transform:uppercase; background:linear-gradient(to top,rgba(0,0,0,.8),rgba(0,0,0,0)); }
  .vA-right { display:flex; flex-direction:column; }
  .vA-head { padding:32px; border-bottom:1px solid var(--rule); }
  .vA-video { flex:1; min-height:280px; border-bottom:1px solid var(--rule); }
  .vA-vinyl { display:flex; align-items:center; gap:20px; padding:20px 24px; cursor:none; }
  .vA-vinyl img { width:96px; height:96px; object-fit:cover; }
  .vA-vinyl-meta { display:flex; flex-direction:column; gap:8px; }
  .vA-vinyl .buy { font-family:'IBM Plex Mono',monospace; font-size:13px; letter-spacing:.12em; }
  .vA-vinyl:hover .buy { text-decoration:underline; }

  /* ── Variant B ── */
  .vB-hero { aspect-ratio:21/9; display:flex; align-items:flex-end; }
  .vB-hero-cap { padding:36px; position:relative; z-index:2; }
  .vB-row { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--rule); border:1px solid var(--rule); border-top:none; }
  .vB-tile { position:relative; margin:0; aspect-ratio:16/11; overflow:hidden; background:var(--bg); cursor:none; }
  .vB-tile img { width:100%; height:100%; object-fit:cover; display:block; transition:filter .4s ease, transform .6s ease; }
  .vB-tile figcaption { position:absolute; bottom:0;left:0;right:0; padding:14px 16px; font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:.24em; text-transform:uppercase; background:linear-gradient(to top,rgba(0,0,0,.8),rgba(0,0,0,0)); z-index:3; }
  .vinyl-overlay { position:absolute; inset:0; z-index:2; display:flex; align-items:center; justify-content:center; opacity:0; transition:opacity .35s ease; }
  .vbuyable:hover img { filter:brightness(.35); transform:scale(1.04); }
  .vbuyable:hover .vinyl-overlay { opacity:1; }
  .buy-btn { border:1px solid var(--fg); padding:13px 24px; border-radius:999px; font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:.2em; text-transform:uppercase; }

  /* ── Variant C ── */
  .vC { display:grid; grid-template-columns:minmax(240px,34%) 1fr; gap:48px; align-items:start; }
  .vC-poster { margin:0; border:1px solid var(--rule); overflow:hidden; }
  .vC-poster img { width:100%; display:block; }
  .vC-info { padding-top:8px; }
  .vC-spec { margin:32px 0; border-top:1px solid var(--rule); }
  .vC-spec > div { display:flex; justify-content:space-between; padding:14px 0; border-bottom:1px solid var(--rule); font-family:'IBM Plex Mono',monospace; font-size:12px; letter-spacing:.1em; }
  .vC-spec dt { color:var(--fg-dim); text-transform:uppercase; font-size:10px; letter-spacing:.24em; }
  .vC-spec dd { margin:0; }
  .vC-actions { display:flex; gap:14px; flex-wrap:wrap; margin-bottom:28px; }
  .vC-btn { display:inline-flex; align-items:center; gap:10px; padding:14px 26px; border:1px solid var(--fg); border-radius:999px; font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:.18em; text-transform:uppercase; cursor:none; transition:background .3s,color .3s; }
  .vC-btn:hover { background:var(--fg); color:var(--bg); }
  .vC-btn.primary { background:var(--fg); color:var(--bg); }
  .vC-btn.primary:hover { background:transparent; color:var(--fg); }
  .vC-btn .tri { width:0;height:0;border-left:9px solid currentColor;border-top:6px solid transparent;border-bottom:6px solid transparent; }
  .vC-vinyl { display:block; border:1px solid var(--rule); overflow:hidden; }
  .vC-vinyl img { width:100%; display:block; transition:filter .4s ease,transform .6s ease; }
  .vC-vinyl:hover img { filter:brightness(.5); transform:scale(1.03); }

  /* ── Variant D — poster centre, video left / vinyl right ── */
  .vD-head { text-align:center; margin-bottom:48px; }
  .vD-row { display:grid; grid-template-columns:1fr 0.92fr 1fr; gap:24px; align-items:center; }
  .vD-poster { margin:0; aspect-ratio:2/3; overflow:hidden; border:1px solid var(--rule); }
  .vD-poster img { width:100%; height:100%; object-fit:cover; display:block; }
  .vD-video { aspect-ratio:1/1; border:1px solid var(--rule); }
  .vD-vinyl { position:relative; aspect-ratio:1/1; overflow:hidden; border:1px solid var(--rule); cursor:none; display:block; }
  .vD-vinyl img { width:100%; height:100%; object-fit:cover; display:block; transition:filter .4s ease, transform .6s ease; }

  /* Lightbox */
  .plb { position:fixed; inset:0; background:rgba(0,0,0,.92); display:none; align-items:center; justify-content:center; z-index:1000; }
  .plb.open { display:flex; }
  .plb-frame { width:min(90vw,1100px); aspect-ratio:16/9; }
  .plb-frame iframe { width:100%; height:100%; border:0; }
  .plb-close { position:absolute; top:24px; right:28px; font-size:34px; line-height:1; color:#fff; background:none; border:none; cursor:pointer; }

  /* Prototype switcher */
  .proto-bar { position:fixed; left:50%; bottom:22px; transform:translateX(-50%); z-index:1100; display:flex; align-items:center; gap:16px; padding:10px 16px; border-radius:999px; background:#fff; color:#111; box-shadow:0 10px 30px rgba(0,0,0,.4); font-family:'IBM Plex Mono',monospace; font-size:12px; letter-spacing:.08em; }
  .proto-bar button { background:#111; color:#fff; border:none; width:30px;height:30px; border-radius:50%; cursor:pointer; font-size:15px; }
  #curV { min-width:190px; text-align:center; }

  @media (max-width:760px){
    .vA { grid-template-columns:1fr; }
    .vD-row { grid-template-columns:1fr; }
    .vD-poster { aspect-ratio:3/4; }
    .vbox { padding:0 16px; }
  }
  @media (hover:none){
    /* touch: show video play + vinyl buy without hover */
    .vplay .play { opacity:1; }
    .vbuyable img { filter:brightness(.42); }
    .vbuyable .vinyl-overlay { opacity:1; }
  }
</style>

<script is:inline>
  const NAMES = { A: 'A — Editorial split', D: 'D — Poster centre' };
  const order = ['A', 'D'];

  function show(v) {
    if (!order.includes(v)) v = 'A';
    document.querySelectorAll('.vbox').forEach((s) => { s.hidden = s.dataset.variant !== v; });
    document.getElementById('curV').textContent = NAMES[v];
    const u = new URL(location.href); u.searchParams.set('variant', v); history.replaceState({}, '', u);
  }
  function current() { return new URL(location.href).searchParams.get('variant') || 'A'; }
  function cycle(d) { const i = order.indexOf(current()); show(order[(i + d + order.length) % order.length]); }

  document.getElementById('prevV').addEventListener('click', () => cycle(-1));
  document.getElementById('nextV').addEventListener('click', () => cycle(1));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') cycle(-1);
    if (e.key === 'ArrowRight') cycle(1);
  });
  show(current());

  // Lightbox
  const plb = document.getElementById('plb');
  const frame = document.getElementById('plbFrame');
  function openLb(yt) { frame.src = `https://www.youtube.com/embed/${yt}?autoplay=1&rel=0&modestbranding=1`; plb.classList.add('open'); }
  function closeLb() { plb.classList.remove('open'); frame.src = ''; }
  document.querySelectorAll('[data-yt]').forEach((el) => {
    el.addEventListener('click', (e) => { e.preventDefault(); openLb(el.dataset.yt); });
  });
  document.getElementById('plbClose').addEventListener('click', closeLb);
  plb.addEventListener('click', (e) => { if (e.target === plb) closeLb(); });
</script>
