---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Rail from '../components/Rail.astro';
import Hero from '../components/Hero.astro';
import Clients from '../components/Clients.astro';
import Work from '../components/Work.astro';
import CinemaTrailer from '../components/CinemaTrailer.astro';
import TvShows from '../components/TvShows.astro';
import Releases from '../components/Releases.astro';
import Contact from '../components/Contact.astro';
import { cloudinaryPoster } from '../lib/cloudinary';
import heroData from '../data/hero.json';

const posterUrl = cloudinaryPoster(heroData.video_url);
---

<Layout posterUrl={posterUrl}>
  <Nav />
  <Rail />
  <main>
    <Hero />
    <Clients />
    <Work />
    <CinemaTrailer />
    <TvShows />
    <Releases />
    <Contact />
  </main>
</Layout>

<script>
  /* ─── Custom Cursor ─── */
  (function () {
    const dotEl = document.getElementById('cursorDot');
    const ringEl = document.getElementById('cursorRing');
    if (!dotEl || !ringEl) return;
    let mx = 0, my = 0, rx = 0, ry = 0;
    window.addEventListener('mousemove', (e) => { mx = e.clientX; my = e.clientY; });
    function tick() {
      rx += (mx - rx) * 0.16;
      ry += (my - ry) * 0.16;
      dotEl!.style.transform = `translate(${mx}px, ${my}px) translate(-50%,-50%)`;
      ringEl!.style.transform = `translate(${rx}px, ${ry}px) translate(-50%,-50%)`;
      requestAnimationFrame(tick);
    }
    tick();
    document.querySelectorAll('a, button, .work-card, .logo-cell, .pill, .dsp, .cf-btn, .cover, .tv-card, .ff-tile')
      .forEach((el) => {
        el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
        el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
      });
  })();

  /* ─── Nav background on scroll ─── */
  (function () {
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('scrolled', window.scrollY > 80);
    }, { passive: true });
  })();

  /* ─── Scroll Spy ─── */
  (function () {
    const sections = ['hero', 'clients', 'work', 'cinema-trailer', 'tvshows', 'releases', 'contact'];
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((en) => {
        if (en.isIntersecting) {
          const id = (en.target as HTMLElement).id;
          document.querySelectorAll('[data-section]').forEach((a) =>
            a.classList.toggle('active', (a as HTMLElement).dataset.section === id)
          );
        }
      });
    }, { rootMargin: '-50% 0px -50% 0px', threshold: 0 });
    sections.forEach((id) => {
      const el = document.getElementById(id);
      if (el) obs.observe(el);
    });
  })();

  /* ─── Logo touch feedback (mobile) ─── */
  (function () {
    if (window.matchMedia('(hover: hover)').matches) return;
    document.querySelectorAll('.logo-cell').forEach((cell) => {
      const on = () => cell.classList.add('is-pressed');
      const off = () => cell.classList.remove('is-pressed');
      cell.addEventListener('touchstart', on, { passive: true });
      cell.addEventListener('touchend', off, { passive: true });
      cell.addEventListener('touchcancel', off, { passive: true });
    });
  })();

  /* ─── Mobile: reveal the card the finger is over while scrolling ─── */
  (function () {
    if (window.matchMedia('(hover: hover)').matches) return;
    const sel = '.work-card, .tv-card';
    let current: Element | null = null;
    function clear() { if (current) { current.classList.remove('revealed'); current = null; } }
    function revealAt(x: number, y: number) {
      const el = document.elementFromPoint(x, y);
      const card = el ? el.closest(sel) : null;
      if (card === current) return;       // no change — skip
      clear();
      if (card) { card.classList.add('revealed'); current = card; }
    }
    const at = (e: TouchEvent) => { const t = e.touches[0]; if (t) revealAt(t.clientX, t.clientY); };
    window.addEventListener('touchstart', at, { passive: true });
    window.addEventListener('touchmove', at, { passive: true });
    window.addEventListener('touchend', clear, { passive: true });
    window.addEventListener('touchcancel', clear, { passive: true });
  })();

  /* ─── Hamburger Menu ─── */
  (function () {
    const h = document.getElementById('hamburger');
    if (!h) return;
    h.addEventListener('click', () => document.body.classList.toggle('menu-open'));
    document.querySelectorAll('.m-link').forEach((a) =>
      a.addEventListener('click', () => document.body.classList.remove('menu-open'))
    );
  })();
</script>
