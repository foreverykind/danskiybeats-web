---
import worksData from '../data/works.json';
import { extractYoutubeId } from '../lib/youtube';

const works = worksData.items.map((w, i) => ({
  i,
  brand: w.brand,
  title: w.title,
  yt: extractYoutubeId(w.youtubeUrl),
}));
const TOTAL = works.length;
---

<section id="work" class="work">
  <div class="section-label">
    <span class="num">03</span>
    <span class="line"></span>
    <span>Selected Works</span>
  </div>
  <div class="section-label-right">
    <span>Works</span>
  </div>

  <div class="work-grid" id="workGrid">
    {works.map((w) => (
      <a class="work-card" href="#" data-idx={w.i} data-yt={w.yt}>
        <div class="thumb"></div>
        <div class="index">{String(w.i + 1).padStart(2, '0')} / {String(TOTAL).padStart(2, '0')}</div>
        <div class="overlay">
          <span class="play"></span>
          <div class="brand">{w.brand}</div>
          <div class="title">{w.title}</div>
        </div>
      </a>
    ))}
  </div>
  <div class="work-loadmore-wrap">
    <button class="work-loadmore" id="workLoadMore" type="button">
      Load more — 12 cases
    </button>
  </div>
</section>

<!-- Video modal -->
<div class="vmodal" id="vmodal" aria-hidden="true">
  <div class="vmodal-bar">
    <span class="meta">
      <span class="num" id="vmCount">01 / 17</span>
      <span class="sep">/</span>
      <span>Selected Works</span>
    </span>
    <button class="vmodal-close" id="vmClose" aria-label="Close"></button>
  </div>
  <div class="vmodal-frame">
    <iframe
      id="vmFrame"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
  <div class="vmodal-foot">
    <div class="title-l">
      <span class="brand" id="vmBrand">Brand</span>
      <span class="sep">·</span>
      <span id="vmTitle">Title</span>
    </div>
    <div class="nav-arrows">
      <button class="vmodal-arrow" id="vmPrev" aria-label="Previous case">
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M9 1 L3 7 L9 13"/>
        </svg>
      </button>
      <button class="vmodal-arrow" id="vmNext" aria-label="Next case">
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M5 1 L11 7 L5 13"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script define:vars={{ works, TOTAL }} is:inline>
  const gradient = 'linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.55) 100%)';

  const thumbObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const thumb = entry.target;
      const card = thumb.closest('[data-yt]');
      const yt = card?.dataset.yt;
      if (!yt || thumb.dataset.loaded) return;
      thumb.dataset.loaded = '1';
      const probe = new Image();
      probe.onload = () => {
        const quality = probe.naturalWidth > 120 ? 'maxresdefault' : 'hqdefault';
        thumb.style.backgroundImage = `${gradient}, url(https://img.youtube.com/vi/${yt}/${quality}.jpg)`;
        thumb.style.backgroundSize = 'cover';
        thumb.style.backgroundPosition = 'center';
      };
      probe.onerror = () => {
        thumb.style.backgroundImage = `${gradient}, url(https://img.youtube.com/vi/${yt}/hqdefault.jpg)`;
        thumb.style.backgroundSize = 'cover';
        thumb.style.backgroundPosition = 'center';
      };
      probe.src = `https://img.youtube.com/vi/${yt}/maxresdefault.jpg`;
      thumbObserver.unobserve(thumb);
    });
  }, { rootMargin: '200px' });

  const allCards = Array.from(document.querySelectorAll('.work-card'));
  allCards.forEach((card, i) => {
    const thumb = card.querySelector('.thumb');
    if (thumb) thumbObserver.observe(thumb);
    card.addEventListener('click', (e) => { e.preventDefault(); openModal(i); });
  });

  // Mobile load-more
  const STEP = 5;
  let visibleCount = STEP;
  const lm = document.getElementById('workLoadMore');

  function updateVisibility() {
    allCards.forEach((card, i) => {
      card.classList.toggle('hidden-mobile', i >= visibleCount);
    });
    const remaining = TOTAL - visibleCount;
    if (remaining <= 0) {
      lm.hidden = true;
    } else {
      lm.hidden = false;
      lm.textContent = `Load more — ${Math.min(remaining, STEP)} cases`;
    }
  }
  updateVisibility();
  lm.addEventListener('click', () => {
    visibleCount = Math.min(visibleCount + STEP, TOTAL);
    updateVisibility();
  });

  // Video modal
  const modal = document.getElementById('vmodal');
  const frame = document.getElementById('vmFrame');
  const vmBrand = document.getElementById('vmBrand');
  const vmTitle = document.getElementById('vmTitle');
  const vmCount = document.getElementById('vmCount');
  let vmIdx = 0;

  function loadVideo(i) {
    const w = works[i];
    frame.src = `https://www.youtube.com/embed/${w.yt}?autoplay=1&rel=0&modestbranding=1&color=white`;
    vmBrand.textContent = w.brand;
    vmTitle.textContent = w.title;
    vmCount.textContent = `${String(i + 1).padStart(2, '0')} / ${String(TOTAL).padStart(2, '0')}`;
    vmIdx = i;
  }

  function openModal(i) {
    loadVideo(i);
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('vmodal-locked');
  }

  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    frame.src = '';
    document.body.classList.remove('vmodal-locked');
  }

  document.getElementById('vmClose').addEventListener('click', closeModal);
  document.getElementById('vmPrev').addEventListener('click', () =>
    loadVideo((vmIdx - 1 + TOTAL) % TOTAL)
  );
  document.getElementById('vmNext').addEventListener('click', () =>
    loadVideo((vmIdx + 1) % TOTAL)
  );
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('open')) return;
    if (e.key === 'Escape')     closeModal();
    if (e.key === 'ArrowLeft')  loadVideo((vmIdx - 1 + TOTAL) % TOTAL);
    if (e.key === 'ArrowRight') loadVideo((vmIdx + 1) % TOTAL);
  });
</script>
