---
import contactData from '../data/contact.json';
const c = contactData;
---

<section id="contact" class="contact">
  <div class="section-label">
    <span class="num">05</span>
    <span class="line"></span>
    <span>Contact</span>
  </div>
  <div class="section-label-right">
    <span>{c.bookings_label}</span>
  </div>

  <div class="crows" style="margin-top: 120px;">
    <div class="crow">
      <div class="lab">All Inquiries</div>
      <div class="data">
        <a href={`mailto:${c.email}`} class="single">{c.email}</a>
      </div>
    </div>

    <div class="crow">
      <div class="lab">Telegram</div>
      <div class="data">
        <a href={c.telegram_url} target="_blank" rel="noopener" class="single">
          {c.telegram_handle}
        </a>
      </div>
    </div>

    <div class="crow">
      <div class="lab">Instagram</div>
      <div class="data">
        <a href={c.instagram_url} target="_blank" rel="noopener" class="single">
          {c.instagram_handle}
        </a>
      </div>
    </div>

    <div class="crow">
      <div class="lab">Listen</div>
      <div class="data">
        {c.dsp.map((d) => (
          <a href={d.url} target="_blank" rel="noopener" class="single">
            {d.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
