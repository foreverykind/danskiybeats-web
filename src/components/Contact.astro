---
import contactData from '../data/contact.json';
const c = contactData;
---

<section id="contact" class="contact">
  <div class="section-label">
    <span class="num">05</span>
    <span class="line"></span>
    <span>Contact</span>
  </div>
  <div class="section-label-right">
    <span>{c.bookings_label}</span>
  </div>

  <div class="crows" style="margin-top: 120px;">
    <div class="crow">
      <div class="lab">All Inquiries</div>
      <div class="data">
        <a href={`mailto:${c.email}`} class="single">{c.email}</a>
      </div>
    </div>

    {c.links.map((l) => (
      <div class="crow">
        <div class="lab">{l.name}</div>
        <div class="data">
          <a href={l.url} target="_blank" rel="noopener" class="single">
            {l.display || l.url}
          </a>
        </div>
      </div>
    ))}
  </div>
</section>
