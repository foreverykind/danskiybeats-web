---
import heroData from '../data/hero.json';
const h = heroData;

// Build optimised Cloudinary URLs for video and poster
// Original: .../video/upload/v.../filename.mp4
// We inject transformation parameters after /upload/
function cloudinaryVideo(url: string): string {
  if (!url || !url.includes('cloudinary.com')) return url;
  return url.replace('/upload/', '/upload/q_auto,f_auto/');
}

function cloudinaryPoster(url: string): string {
  if (!url || !url.includes('cloudinary.com')) return '';
  // Generate a JPEG thumbnail from the first frame
  return url
    .replace('/upload/', '/upload/q_auto,f_jpg,so_0/')
    .replace(/\.(mp4|mov|webm)$/i, '.jpg');
}

const optimisedVideoUrl  = cloudinaryVideo(h.video_url);
const posterUrl          = cloudinaryPoster(h.video_url);
---

<section id="hero" class="hero">
  <div class="hero-video" aria-hidden="true">
    {h.video_url ? (
      <video
        class="hero-reel"
        autoplay
        muted
        loop
        playsinline
        preload="none"
        poster={posterUrl || undefined}
        src={optimisedVideoUrl}
      />
    ) : (
      <>
        <div class="vignette-dot"></div>
        <div class="placeholder-tag">[ SHOWREEL{h.reel_duration ? ` · ${h.reel_duration}` : ''} ]</div>
      </>
    )}
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="section-label">
    <span class="num">01</span>
    <span class="line"></span>
    <span>Intro</span>
  </div>
  {(h.reel_year || h.reel_duration) && (
    <div class="section-label-right">
      {h.reel_year && <span>Reel {h.reel_year}</span>}
      {h.reel_duration && <span class="num">/ {h.reel_duration}</span>}
    </div>
  )}

  <div class="hero-inner">
    <div class="hero-left">
      <div class="eyebrow">
        {h.eyebrow.map((item, i) => (
          <>
            {i > 0 && <span class="sep">·</span>}
            <span>{item}</span>
          </>
        ))}
      </div>
      <div class="tagline">{h.tagline}</div>
      <div class="hero-cta">
        {h.cta.map((btn) => (
          <a href={btn.href} class="pill">{btn.label} <span class="arrow"></span></a>
        ))}
      </div>
    </div>
  </div>

  <div class="hero-foot">
    <span></span>
    <span class="scroll">
      <span>Scroll</span>
      <span class="bar"></span>
    </span>
  </div>
</section>

<script>
  const v = document.querySelector('.hero-reel') as HTMLVideoElement | null;
  if (v) {
    v.play().catch(() => {
      const resume = () => { v.play().catch(() => {}); document.removeEventListener('touchstart', resume); };
      document.addEventListener('touchstart', resume, { passive: true });
    });
  }
</script>

