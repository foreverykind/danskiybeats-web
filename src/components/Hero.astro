---
import { cloudinaryVideo, cloudinaryVideoMobile, cloudinaryPoster } from '../lib/cloudinary';
import heroData from '../data/hero.json';
const h = heroData;

const optimisedVideoUrl = cloudinaryVideo(h.video_url);
const mobileVideoUrl = cloudinaryVideoMobile(h.video_url);
const posterUrl = cloudinaryPoster(h.video_url);
---

<section id="hero" class="hero">
  <div class="hero-video" aria-hidden="true">
    {h.video_url ? (
      <>
        <img
          id="heroPoster"
          class="hero-reel"
          src={posterUrl}
          alt=""
          fetchpriority="high"
          decoding="async"
        />
        <video
          id="heroVideo"
          class="hero-reel"
          style="display:none"
          muted
          loop
          playsinline
          preload="none"
          data-src={optimisedVideoUrl}
          data-src-mobile={mobileVideoUrl}
        />
      </>
    ) : (
      <>
        <div class="vignette-dot"></div>
        <div class="placeholder-tag">[ SHOWREEL{h.reel_duration ? ` · ${h.reel_duration}` : ''} ]</div>
      </>
    )}
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="section-label">
    <span class="num">01</span>
    <span class="line"></span>
    <span>Home</span>
  </div>
  {(h.reel_year || h.reel_duration) && (
    <div class="section-label-right">
      {h.reel_year && <span>Reel {h.reel_year}</span>}
      {h.reel_duration && <span class="num">/ {h.reel_duration}</span>}
    </div>
  )}

  <div class="hero-inner">
    <div class="hero-left">
      <div class="eyebrow">
        {h.eyebrow.map((item, i) => (
          <>
            {i > 0 && <span class="sep">·</span>}
            <span>{item}</span>
          </>
        ))}
      </div>
      <div class="tagline">{h.tagline}</div>
      <div class="hero-cta">
        {h.cta.map((btn) => (
          <a href={btn.href} class="pill">{btn.label} <span class="arrow"></span></a>
        ))}
      </div>
    </div>
  </div>

  <div class="hero-foot">
    <span></span>
    <span class="scroll">
      <span>Scroll</span>
      <span class="bar"></span>
    </span>
  </div>
</section>

<script>
  const poster = document.getElementById('heroPoster') as HTMLImageElement | null;
  const video  = document.getElementById('heroVideo')  as HTMLVideoElement | null;

  if (video) {
    const load = () => {
      const isMobile = window.matchMedia('(max-width: 760px)').matches;
      video.src = (isMobile && video.dataset.srcMobile) ? video.dataset.srcMobile : video.dataset.src!;
      video.style.display = '';
      video.load();
      video.play()
        .then(() => { if (poster) poster.style.display = 'none'; })
        .catch(() => {});
    };
    if (document.readyState === 'complete') load();
    else window.addEventListener('load', load);
  }
</script>
