---
const stops = [
  { href: '#hero',     section: 'hero',     label: 'Home' },
  { href: '#clients',  section: 'clients',  label: 'Clients' },
  { href: '#work',     section: 'work',     label: 'Work' },
  { href: '#cinema-trailer', section: 'cinema-trailer', label: 'Cinema & Trailer' },
  { href: '#tvshows',  section: 'tvshows',  label: 'TV & Shows' },
  { href: '#releases', section: 'releases', label: 'Releases' },
  { href: '#contact',  section: 'contact',  label: 'Contact' },
];
---

<div class="rail" id="rail">
  {stops.map(({ href, section, label }) => (
    <a href={href} data-section={section}>
      <span class="d"></span>
      <span class="lbl">{label}</span>
    </a>
  ))}
</div>
