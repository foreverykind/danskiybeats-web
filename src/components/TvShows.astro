---
import tvData from '../data/tvshows.json';
const shows = tvData.items;
---

<section id="tvshows" class="tvshows">
  <div class="section-label">
    <span class="num">05</span>
    <span class="line"></span>
    <span>TV &amp; Shows</span>
  </div>
  <div class="section-label-right">
    <span>Featured Music</span>
    <span class="num">/ {String(shows.length).padStart(2, '0')}</span>
  </div>

  <div class="tv-grid" id="tvGrid">
    {shows.map((s) => (
      <div class="tv-card">
        <img class="tv-art" src={s.image} alt={`${s.show} — ${s.channel}`} loading="lazy" decoding="async" />
        <div class="tv-overlay">
          <div class="tv-show">{s.show}</div>
          <div class="tv-channel">{s.channel}</div>
        </div>
      </div>
    ))}
  </div>
  <div class="work-loadmore-wrap">
    <button class="work-loadmore" id="tvLoadMore" type="button">Show more</button>
  </div>
</section>

<script is:inline>
  /* Mobile: show TV posters in batches of 4 */
  (function () {
    const STEP = 4;
    let visibleCount = STEP;
    const cards = Array.from(document.querySelectorAll('#tvGrid .tv-card'));
    const TOTAL = cards.length;
    const lm = document.getElementById('tvLoadMore');
    if (!lm) return;
    function update() {
      cards.forEach((c, i) => c.classList.toggle('hidden-mobile', i >= visibleCount));
      const remaining = TOTAL - visibleCount;
      if (remaining <= 0) { lm.hidden = true; }
      else { lm.hidden = false; lm.textContent = `Show more — ${Math.min(remaining, STEP)} shows`; }
    }
    update();
    lm.addEventListener('click', () => {
      visibleCount = Math.min(visibleCount + STEP, TOTAL);
      update();
    });
  })();
</script>
